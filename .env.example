# ─────────────────────────────────────────────────────────────
# instal-hampl.net — environment variables
# Copy to `.env.local` for local dev, and add these in Vercel → Settings → Environment Variables.
# NEXT_PUBLIC_* vars are exposed to the browser; everything else is server-only.
# ─────────────────────────────────────────────────────────────

# --- Site ---------------------------------------------------------------
# Canonical origin, no trailing slash. Drives canonical tags, sitemap.xml,
# robots.txt and Open Graph URLs. On Vercel set this to the production domain.
NEXT_PUBLIC_SITE_URL=https://www.instal-hampl.net

# --- Contentful (Content Delivery API) ----------------------------------
CONTENTFUL_SPACE_ID=
CONTENTFUL_ENVIRONMENT=master
# Content Delivery token (published content, read-only)
CONTENTFUL_DELIVERY_TOKEN=
# Content Preview token (draft content) — optional, enables Draft Mode preview
CONTENTFUL_PREVIEW_TOKEN=

# --- Contentful (Content Management API) --------------------------------
# Personal Access Token (Settings → CMA tokens). Read/WRITE — used ONLY by the
# CLI content-model migration (`npm run cf:migrate`), never by the app runtime.
CONTENTFUL_MANAGEMENT_TOKEN=

# --- On-demand revalidation & preview -----------------------------------
# Shared secret sent by the Contentful webhook to /api/revalidate to bust the cache on publish.
CONTENTFUL_REVALIDATE_SECRET=
# Secret guarding the /api/draft preview route.
CONTENTFUL_PREVIEW_SECRET=

# --- Analytics / Ad tracking (client) -----------------------------------
# GA4 Measurement ID, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Meta (Facebook) Pixel ID, e.g. 123456789012345
NEXT_PUBLIC_FB_PIXEL_ID=
# Optional: Google site verification token for Search Console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
